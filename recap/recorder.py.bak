"""recap – recording session controller.

Orchestrates video capture, audio capture, and the FFmpeg encoding
subprocess.  This is the main entry-point for the library API.
"""

from __future__ import annotations

import ctypes
import ctypes.wintypes
import enum
import json
import logging
import os
import subprocess
import threading
import time
from pathlib import Path
from typing import BinaryIO, Optional

from recap.config import RecordingConfig
from recap.exceptions import (
    CaptureError,
    ConfigError,
    FFmpegError,
    FFmpegNotFoundError,
    RecapError,
)
from recap.ffmpeg import FFmpegInfo, find_ffmpeg

log = logging.getLogger(__name__)


class RecorderState(enum.Enum):
    IDLE = "idle"
    STARTING = "starting"
    RECORDING = "recording"
    STOPPING = "stopping"
    STOPPED = "stopped"
    ERROR = "error"


class Recorder:
    """High-level recording session controller.

    Usage::

        config = RecordingConfig(output="out.mp4")
        rec = Recorder(config)
        rec.start()
        # ... wait or do other work ...
        rec.stop()
        rec.wait()
    """

    def __init__(self, config: RecordingConfig) -> None:
        self._config = config
        self._state = RecorderState.IDLE
        self._lock = threading.Lock()

        self._ffmpeg_info: Optional[FFmpegInfo] = None
        self._ffmpeg_proc: Optional[subprocess.Popen] = None
        self._video_capture = None  # Optional[VideoCapture]
        self._audio_capture = None  # Optional[AudioCapture]
        self._video_pipe_writer: Optional[_PipeWriter] = None
        self._audio_pipe_writer: Optional[_PipeWriter] = None
        self._duration_timer: Optional[threading.Timer] = None
        self._error: Optional[Exception] = None

    # ------------------------------------------------------------------
    # Properties
    # ------------------------------------------------------------------

    @property
    def state(self) -> RecorderState:
        return self._state

    @property
    def config(self) -> RecordingConfig:
        return self._config

    @property
    def error(self) -> Optional[Exception]:
        return self._error

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------

    def start(self) -> None:
        """Begin recording.

        Resolves FFmpeg, starts capture threads, and launches the FFmpeg
        encoding subprocess.
        """
        with self._lock:
            if self._state != RecorderState.IDLE:
                raise RecapError(
                    f"Cannot start: recorder is in state {self._state.value}"
                )
            self._state = RecorderState.STARTING

        try:
            self._ffmpeg_info = find_ffmpeg(self._config.ffmpeg)
            log.info("Using FFmpeg: %s (%s)", self._ffmpeg_info.path, self._ffmpeg_info.version)
            self._launch(self._ffmpeg_info)
            with self._lock:
                self._state = RecorderState.RECORDING
            log.info("Recording started -> %s", self._config.output)
        except Exception as exc:
            with self._lock:
                self._state = RecorderState.ERROR
                self._error = exc
            raise

    def stop(self) -> None:
        """Stop recording gracefully.

        Signals capture threads to finish and closes the FFmpeg stdin pipe
        so FFmpeg can finalize the output file.
        """
        with self._lock:
            if self._state not in (
                RecorderState.RECORDING,
                RecorderState.STARTING,
            ):
                return
            self._state = RecorderState.STOPPING

        log.info("Stopping recording...")

        if self._duration_timer is not None:
            self._duration_timer.cancel()
            self._duration_timer = None

        # Stop captures (they write to FFmpeg stdin pipes)
        if self._video_capture is not None:
            self._video_capture.stop()
        if self._audio_capture is not None:
            self._audio_capture.stop()

    def wait(self, timeout: Optional[float] = None) -> int:
        """Wait for the recording to finish and return the exit code.

        Returns 0 on success, non-zero otherwise.  After ``wait()``
        returns, ``state`` is either STOPPED or ERROR.
        """
        # Wait for capture threads to finish writing
        if self._video_capture is not None:
            self._video_capture.wait(timeout=timeout)
        if self._audio_capture is not None:
            self._audio_capture.wait(timeout=timeout)

        wait_timeout = timeout or 30

        # Close video input (stdin or named pipe)
        if self._video_pipe_writer is not None:
            try:
                self._video_pipe_writer.close()
            except Exception:
                pass
            self._video_pipe_writer = None
        elif self._ffmpeg_proc is not None and self._ffmpeg_proc.stdin:
            try:
                self._ffmpeg_proc.stdin.close()
            except Exception:
                pass

        # Close audio input (stdin or named pipe)
        if self._audio_pipe_writer is not None:
            try:
                self._audio_pipe_writer.close()
            except Exception:
                pass
            self._audio_pipe_writer = None

        if self._ffmpeg_proc is not None:
            try:
                self._ffmpeg_proc.wait(timeout=wait_timeout)
            except subprocess.TimeoutExpired:
                log.warning("FFmpeg did not exit in time, terminating.")
                self._ffmpeg_proc.terminate()
                self._ffmpeg_proc.wait(timeout=5)
            rc = self._ffmpeg_proc.returncode
            if rc != 0:
                with self._lock:
                    self._state = RecorderState.ERROR
                    self._error = FFmpegError(f"FFmpeg exited with code {rc}")
                return rc

        with self._lock:
            self._state = RecorderState.STOPPED
        log.info("Recording saved -> %s", self._config.output)
        return 0

    # ------------------------------------------------------------------
    # Internal helpers
    # ------------------------------------------------------------------

    def _launch(self, ffinfo: FFmpegInfo) -> None:
        """Set up captures and the FFmpeg subprocess.

        Video + audio:
            video thread  -> Windows named pipe (video)
            audio thread  -> Windows named pipe (audio)
            Both feed one FFmpeg process for synchronised muxing.

        Single-input (video-only or audio-only):
            capture thread -> proc.stdin -> FFmpeg -> output
        """
        self._ffmpeg_proc = None
        self._video_pipe_writer = None
        self._audio_pipe_writer = None

        has_video = self._config.capture_video
        has_audio = (self._config.capture_audio
                     and not self._config.video_only
                     and not self._config.no_audio)

        # -- Set up capture objects --
        target_kwargs = {}
        if has_video:
            from recap.video import VideoCapture

            if self._config.window_handle is not None:
                target_kwargs["window_handle"] = self._config.window_handle
            elif self._config.window_title is not None:
                from recap.discovery import find_window_by_title
                win = find_window_by_title(self._config.window_title)
                if win is None:
                    raise CaptureError(
                        f"No visible window matching '{self._config.window_title}'"
                    )
                target_kwargs["window_handle"] = win.handle
            else:
                target_kwargs["monitor_index"] = (
                    self._config.monitor if self._config.monitor is not None else 0
                )

            self._video_relay = _StdinRelay()
            self._video_capture = VideoCapture(
                self._video_relay, fps=self._config.fps, **target_kwargs
            )

        if has_audio:
            from recap.audio import AudioCapture
            self._audio_relay = _StdinRelay(buffer_writes=True)
            self._audio_capture = AudioCapture(self._audio_relay)

        # -- Start captures to discover format info --
        width, height = 0, 0
        if has_video:
            self._video_capture.start()
            if not self._video_capture.wait_ready(timeout=10):
                raise CaptureError("Video capture did not start in time.")
            width = self._video_capture.width
            height = self._video_capture.height

        audio_fmt, audio_sr, audio_ch = "f32le", 48000, 2
        if has_audio:
            self._audio_capture.start()
            time.sleep(0.3)
            audio_fmt = "f32le" if self._audio_capture.bits_per_sample == 32 else "s16le"
            audio_sr = self._audio_capture.sample_rate
            audio_ch = self._audio_capture.channels

        ffmpeg = str(ffinfo.path)
        overwrite_flag = "-y" if self._config.overwrite else "-n"

        if has_video and has_audio:
            # -- COMBINED: single FFmpeg, two named pipes --
            pipe_base = f"\\\\.\\pipe\\recap_{os.getpid()}_{id(self)}"
            video_pipe_name = f"{pipe_base}_v"
            audio_pipe_name = f"{pipe_base}_a"
            video_pipe_handle = _create_named_pipe(
                video_pipe_name, buffer_size=1048576,
            )
            audio_pipe_handle = _create_named_pipe(audio_pipe_name)

            cmd = [
                ffmpeg, overwrite_flag,
                "-probesize", "32", "-analyzeduration", "0",
                "-f", "rawvideo", "-pixel_format", "bgra",
                "-video_size", f"{width}x{height}",
                "-framerate", str(self._config.fps),
                "-thread_queue_size", "64",
                "-i", video_pipe_name,
                "-probesize", "32", "-analyzeduration", "0",
                "-f", audio_fmt,
                "-ar", str(audio_sr),
                "-ac", str(audio_ch),
                "-thread_queue_size", "1024",
                "-i", audio_pipe_name,
                "-c:v", "libx264", "-preset", "ultrafast",
                "-pix_fmt", "yuv420p",
                "-c:a", "aac", "-b:a", "192k",
                "-shortest",
                str(self._config.output),
            ]
            log.debug("FFmpeg command: %s", cmd)

            self._ffmpeg_proc = subprocess.Popen(
                cmd,
                stderr=subprocess.DEVNULL,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )

            # Connect both pipes in parallel background threads.
            # FFmpeg opens inputs sequentially, so each ConnectNamedPipe
            # call unblocks as FFmpeg reaches that input.
            def _connect_video_pipe():
                _connect_named_pipe(video_pipe_handle)
                self._video_pipe_writer = _PipeWriter(video_pipe_handle)
                self._video_relay.set_target(self._video_pipe_writer)

            def _connect_audio_pipe():
                _connect_named_pipe(audio_pipe_handle)
                self._audio_pipe_writer = _PipeWriter(audio_pipe_handle)
                self._audio_relay.set_target(self._audio_pipe_writer)

            threading.Thread(
                target=_connect_video_pipe, daemon=True,
                name="recap-vpipe-connect",
            ).start()
            threading.Thread(
                target=_connect_audio_pipe, daemon=True,
                name="recap-apipe-connect",
            ).start()

        elif has_video:
            # -- VIDEO ONLY --
            cmd = [
                ffmpeg, overwrite_flag,
                "-f", "rawvideo", "-pixel_format", "bgra",
                "-video_size", f"{width}x{height}",
                "-framerate", str(self._config.fps),
                "-i", "pipe:0",
                "-c:v", "libx264", "-preset", "ultrafast",
                "-pix_fmt", "yuv420p", "-an",
                str(self._config.output),
            ]
            log.debug("FFmpeg command: %s", cmd)

            self._ffmpeg_proc = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )
            self._video_relay.set_target(self._ffmpeg_proc.stdin)

        elif has_audio:
            # -- AUDIO ONLY --
            cmd: list[str] = [ffmpeg, overwrite_flag]
            cmd += [
                "-f", audio_fmt,
                "-ar", str(audio_sr),
                "-ac", str(audio_ch),
                "-i", "pipe:0",
            ]
            output_ext = Path(self._config.output).suffix.lower()
            if output_ext in (".wav",):
                cmd += ["-c:a", "pcm_s16le"]
            else:
                cmd += ["-c:a", "aac", "-b:a", "192k"]
            cmd.append(str(self._config.output))
            log.debug("FFmpeg command: %s", cmd)

            self._ffmpeg_proc = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                creationflags=subprocess.CREATE_NO_WINDOW,
            )
            self._audio_relay.set_target(self._ffmpeg_proc.stdin)

        # Duration-limited recording
        if self._config.duration is not None:
            self._duration_timer = threading.Timer(
                self._config.duration, self.stop
            )
            self._duration_timer.daemon = True
            self._duration_timer.start()


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

class _StdinRelay:
    """Thread-safe write relay.

    Capture threads call ``.write()`` immediately.  In blocking mode
    (default), writes block until ``set_target()`` is called.  In
    buffering mode, writes are stored in memory and flushed when the
    target becomes available — used for audio to avoid WASAPI buffer
    overflow while the named pipe connects.
    """

    def __init__(self, buffer_writes: bool = False) -> None:
        self._target: Optional[BinaryIO] = None
        self._ready = threading.Event()
        self._buffer_writes = buffer_writes
        self._buf: list[bytes] = []
        self._buf_lock = threading.Lock()

    def set_target(self, target) -> None:
        if self._buffer_writes:
            with self._buf_lock:
                self._target = target
                for chunk in self._buf:
                    try:
                        target.write(chunk)
                    except (BrokenPipeError, OSError):
                        break
                self._buf.clear()
            self._ready.set()
        else:
            self._target = target
            self._ready.set()

    def write(self, data: bytes | bytearray | memoryview) -> int:
        if self._buffer_writes:
            with self._buf_lock:
                if self._target is not None:
                    try:
                        self._target.write(data)
                    except (BrokenPipeError, OSError):
                        raise BrokenPipeError("Target closed")
                else:
                    self._buf.append(bytes(data))
                return len(data)
        if not self._ready.wait(timeout=30):
            raise CaptureError("Timed out waiting for FFmpeg to start.")
        try:
            self._target.write(data)
            return len(data)
        except (BrokenPipeError, OSError):
            raise BrokenPipeError("FFmpeg stdin closed")

    def flush(self) -> None:
        if self._target is not None:
            try:
                self._target.flush()
            except Exception:
                pass

    @property
    def closed(self) -> bool:
        if self._target is not None:
            return getattr(self._target, 'closed', False)
        return False


# ---------------------------------------------------------------------------
# Windows named-pipe helpers
# ---------------------------------------------------------------------------

_PIPE_ACCESS_OUTBOUND = 0x00000002
_PIPE_TYPE_BYTE = 0x00000000
_PIPE_WAIT = 0x00000000
_INVALID_HANDLE_VALUE = ctypes.wintypes.HANDLE(-1).value

_kernel32 = ctypes.windll.kernel32


def _create_named_pipe(name: str, buffer_size: int = 65536) -> int:
    """Create a Windows named pipe (server side, outbound only)."""
    handle = _kernel32.CreateNamedPipeW(
        name,
        _PIPE_ACCESS_OUTBOUND,
        _PIPE_TYPE_BYTE | _PIPE_WAIT,
        1,           # max instances
        buffer_size, # out buffer
        0,           # in buffer (unused for outbound)
        0,           # default timeout
        None,        # security attributes
    )
    if handle == _INVALID_HANDLE_VALUE:
        raise CaptureError(f"Failed to create named pipe: {name}")
    return handle


def _connect_named_pipe(handle: int) -> None:
    """Block until a client (FFmpeg) connects to the named pipe."""
    result = _kernel32.ConnectNamedPipe(handle, None)
    if not result:
        err = ctypes.GetLastError()
        # ERROR_PIPE_CONNECTED (535) = client already connected before call
        if err != 535:
            raise CaptureError(f"ConnectNamedPipe failed (error {err})")


class _PipeWriter:
    """File-like wrapper around a Windows named-pipe handle."""

    def __init__(self, handle: int) -> None:
        self._handle = handle

    def write(self, data: bytes | bytearray | memoryview) -> int:
        if isinstance(data, memoryview):
            data = bytes(data)
        written = ctypes.wintypes.DWORD()
        ok = _kernel32.WriteFile(
            self._handle, data, len(data),
            ctypes.byref(written), None,
        )
        if not ok:
            raise BrokenPipeError("WriteFile on named pipe failed")
        return written.value

    def flush(self) -> None:
        if self._handle is not None:
            _kernel32.FlushFileBuffers(self._handle)

    def close(self) -> None:
        if self._handle is not None:
            try:
                _kernel32.FlushFileBuffers(self._handle)
            except Exception:
                pass
            _kernel32.DisconnectNamedPipe(self._handle)
            _kernel32.CloseHandle(self._handle)
            self._handle = None

    @property
    def closed(self) -> bool:
        return self._handle is None
